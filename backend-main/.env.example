# Copy to .env and fill in values. Never commit .env.

DATABASE_URL="mysql://user:password@localhost:3306/kellishub"
JWT_SECRET="your-secret-key"
CHAT_ENCRYPTION_KEY="your-32-char-key-or-same-as-jwt"
PAYSTACK_SECRET_KEY="sk_test_..."
PAYSTACK_CALLBACK_URL="http://localhost:5173/shop"
FRONTEND_URL="http://localhost:5173"

# GMPL supplier (Excel order fulfillment)
GMPL_API_URL="https://api.gmpl.com"
GMPL_API_KEY="ak_your_gmpl_api_key"

# GMPL auto-export (pending orders → batch → GMPL on a schedule)
GMPL_AUTO_EXPORT="false"
GMPL_AUTO_INTERVAL_MS="300000"
GMPL_MIN_PENDING_COUNT="1"
GMPL_AUTO_RETRY_FAILED="true"
GMPL_AUTO_MAX_RETRIES="3"
# GMPL_AUTO_EXPORT_ADMIN_USER_ID="1"

PORT=5000
NODE_ENV=development
