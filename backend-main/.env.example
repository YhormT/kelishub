# Copy to .env and fill in values. Never commit .env.

DATABASE_URL="mysql://user:password@localhost:3306/kellishub"
JWT_SECRET="your-secret-key"
CHAT_ENCRYPTION_KEY="your-32-char-key-or-same-as-jwt"
PAYSTACK_SECRET_KEY="sk_test_..."
PAYSTACK_CALLBACK_URL="http://localhost:5173/shop"
FRONTEND_URL="http://localhost:5173"

# GMPL supplier (Get More Pay Less Data House — Agent API v1)
GMPL_API_URL="https://api.getmorepaylessdatahouse.net/api/v1"
GMPL_API_KEY="ak_live_your_gmpl_api_key"

# GMPL auto-export (pending orders → batch → GMPL on a schedule)
GMPL_AUTO_EXPORT="false"
GMPL_AUTO_INTERVAL_MS="300000"
GMPL_MIN_PENDING_COUNT="1"
# Min pending purchaser orders before auto-export (1 = a single waiting order is exported)
# Max purchaser orders per auto-export cycle (FIFO). Next cycle sends more without waiting for GMPL completion. 0 = unlimited.
GMPL_MAX_ORDERS_PER_CYCLE="3"
GMPL_AUTO_RETRY_FAILED="true"
GMPL_AUTO_MAX_RETRIES="3"
# GMPL_AUTO_EXPORT_ADMIN_USER_ID="1"

# GMPL status sync (webhook + poll submitted MTN batches → Completed)
GMPL_STATUS_SYNC="true"
GMPL_STATUS_SYNC_INTERVAL_MS="180000"
# Webhook signing secret from GMPL (X-Telecom-Signature HMAC). Optional for dev.
# GMPL_WEBHOOK_SECRET="whsec_..."

PORT=5000
NODE_ENV=development
