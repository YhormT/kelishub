or\\(\"Passwords do not match\\.\"\\);\n      setLoading\\(false\\);\n      return;\n    \\}\n\n    if \\(password\\.length < 6\\) \\{\n      setError\\(\"Password must be at least 6 characters\\.\"\\);\n      setLoading\\(false\\);\n      return;\n    \\}\n\n    try \\{\n      const response = await axios\\.post\\(`\\$\\{BASE_URL\\}/api/auth/register`, \\{\n        name,\n        email,\n        password,\n        phone: phone \\|\\| undefined,\n      \\}\\);\n\n      const \\{ token, user \\} = response\\.data;\n\n      localStorage\\.setItem\\(\"token\", token\\);\n      localStorage\\.setItem\\(\"role\", user\\?\\.role \\|\\| \"USER\"\\);\n      localStorage\\.setItem\\(\"name\", user\\?\\.name \\|\\| \"\"\\);\n      localStorage\\.setItem\\(\"email\", user\\?\\.email \\|\\| email\\);\n      localStorage\\.setItem\\(\"userId\", user\\?\\.id \\|\\| \"\"\\);\n      localStorage\\.setItem\\(\"isLoggedIn\", \"true\"\\);\n      localStorage\\.setItem\\(\"isSuspended\", \"false\"\\);\n\n      toast\\.success\\(\"Registration successful\\. Redirecting\\.\\.\\.\"\\);\n      redirectToDashboard\\(user\\?\\.role\\);\n    \\} catch \\(err\\) \\{\n      setError\\(err\\.response\\?\\.data\\?\\.message \\|\\| \"Registration failed\\. Please try again\\.\"\\);\n      setLoading\\(false\\);\n    \\}\n  \\};\n\n  return \\(\n    <div className=\"min-h-screen bg-slate-50 text-slate-900 flex\">\n      <div className=\"hidden lg:flex lg:w-1/2 bg-blue-600 text-white relative overflow-hidden\">\n        <div className=\"absolute inset-0 opacity-25 bg-\\[radial-gradient\\(circle_at_top_left,_rgba\\(59,130,246,0\\.8\\),_transparent_30%\\),radial-gradient\\(circle_at_bottom_right,_rgba\\(252,211,77,0\\.35\\),_transparent_30%\\)\\]\"></div>\n        <div className=\"relative z-10 flex flex-col justify-between p-12\">\n          <div>\n            <div className=\"flex items-center gap-3 mb-8\">\n              <div className=\"w-12 h-12 rounded-3xl bg-white/15 flex items-center justify-center\">\n                <Shield className=\"w-6 h-6 text-white\" />\n              </div>\n              <div>\n                <p className=\"text-xs uppercase tracking-\\[0\\.3em\\] text-blue-200\">kellishub</p>\n                <h1 className=\"text-3xl font-semibold\">Welcome to kellishub</h1>\n              </div>\n            </div>\n            <p className=\"max-w-sm text-blue-100 leading-relaxed\">\n              Register now to start buying data bundles across MTN, AirtelTigo, and Telecel\\. Your account gives you access to fast, safe, and convenient service any time\\.\n            </p>\n          </div>\n\n          <div className=\"space-y-6\">\n            <div className=\"flex items-center gap-4\">\n              <div className=\"w-12 h-12 rounded-3xl bg-white/10 flex items-center justify-center\">\n                <Zap className=\"w-5 h-5 text-yellow-300\" />\n              </div>\n              <div>\n                <p className=\"font-semibold\">Fast signup</p>\n                <p className=\"text-sm text-blue-100\">Start using kellishub in minutes\\.</p>\n              </div>\n            </div>\n            <div className=\"flex items-center gap-4\">\n              <div className=\"w-12 h-12 rounded-3xl bg-white/10 flex items-center justify-center\">\n                <Wifi className=\"w-5 h-5 text-white\" />\n              </div>\n              <div>\n                <p className=\"font-semibold\">All networks supported</p>\n                <p className=\"text-sm text-blue-100\">One account for every Ghanaian network\\.</p>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <div className=\"flex-1 flex items-center justify-center p-6 sm:p-10\">\n        <motion\\.div\n          initial=\\{\\{ opacity: 0, y: 20 \\}\\}\n          animate=\\{\\{ opacity: 1, y: 0 \\}\\}\n          transition=\\{\\{ duration: 0\\.45 \\}\\}\n          className=\"w-full max-w-md rounded-\\[2rem\\] bg-white p-8 shadow-xl\"\n        >\n          <div className=\"mb-8 text-center\">\n            <div className=\"inline-flex items-center justify-center gap-3 mb-4\">\n              <div className=\"w-11 h-11 rounded-3xl bg-blue-600 flex items-center justify-center text-white\">K</div>\n              <span className=\"text-xl font-semibold\">kellishub</span>\n            </div>\n            <h2 className=\"text-2xl font-bold text-slate-900 mb-2\">Create your account</h2>\n            <p className=\"text-sm text-slate-500\">Register for secure access to your dashboard and data orders\\.</p>\n          </div>\n\n          \\{error && \\(\n            <div className=\"mb-6 rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700\">\n              \\{error\\}\n            </div>\n          \\)\\}\n\n          <form onSubmit=\\{handleRegister\\} className=\"space-y-5\">\n            <div>\n              <label className=\"block text-sm font-medium text-slate-700 mb-2\">Full name</label>\n              <div className=\"relative\">\n                <div className=\"pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3 text-slate-400\">\n                  <User className=\"w-5 h-5\" />\n                </div>\n                <input\n                  type=\"text\"\n                  value=\\{name\\}\n                  onChange=\\{\\(event\\) => setName\\(event\\.target\\.value\\)\\}\n                  placeholder=\"John Doe\"\n                  required\n                  className=\"w-full rounded-2xl border border-slate-200 bg-slate-50 py-3 pl-12 pr-4 text-sm text-slate-900 outline-none transition focus:border-blue-500 focus:ring-2 focus:ring-blue-500/10\"\n                />\n              </div>\n            </div>\n\n            <div>\n              <label className=\"block text-sm font-medium text-slate-700 mb-2\">Email address</label>\n              <div className=\"relative\">\n                <div className=\"pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3 text-slate-400\">\n                  <Mail className=\"w-5 h-5\" />\n                </div>\n                <input\n                  type=\"email\"\n                  value=\\{email\\}\n                  onChange=\\{\\(event\\) => setEmail\\(event\\.target\\.value\\)\\}\n                  placeholder=\"you@example\\.com\"\n                  required\n                  className=\"w-full rounded-2xl border border-slate-200 bg-slate-50 py-3 pl-12 pr-4 text-sm text-slate-900 outline-none transition focus:border-blue-500 focus:ring-2 focus:ring-blue-500/10\"\n                />\n              </div>\n            </div>\n\n            <div>\n              <label className=\"block text-sm font-medium text-slate-700 mb-2\">Phone number</label>\n              <div className=\"relative\">\n                <div className=\"pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3 text-slate-400\">\n                  <Phone className=\"w-5 h-5\" />\n                </div>\n                <input\n                  type=\"tel\"\n                  value=\\{phone\\}\n                  onChange=\\{\\(event\\) => setPhone\\(event\\.target\\.value\\)\\}\n                  placeholder=\"0244 000 000\"\n                  className=\"w-full rounded-2xl border border-slate-200 bg-slate-50 py-3 pl-12 pr-4 text-sm text-slate-900 outline-none transition focus:border-blue-500 focus:ring-2 focus:ring-blue-500/10\"\n                />\n              </div>\n            </div>\n\n            <div>\n              <label className=\"block text-sm font-medium text-slate-700 mb-2\">Password</label>\n              <div className=\"relative\">\n                <div className=\"pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3 text-slate-400\">\n                  <Lock className=\"w-5 h-5\" />\n                </div>\n                <input\n                  type=\\{showPassword \\? \"text\" : \"password\"\\}\n                  value=\\{password\\}\n                  onChange=\\{\\(event\\) => setPassword\\(event\\.target\\.value\\)\\}\n                  placeholder=\"At least 6 characters\"\n                  required\n                  className=\"w-full rounded-2xl border border-slate-200 bg-slate-50 py-3 pl-12 pr-12 text-sm text-slate-900 outline-none transition focus:border-blue-500 focus:ring-2 focus:ring-blue-500/10\"\n                />\n                <button\n                  type=\"button\"\n                  onClick=\\{\\(\\) => setShowPassword\\(\\(current\\) => !current\\)\\}\n                  className=\"absolute inset-y-0 right-0 flex items-center pr-3 text-slate-500 hover:text-slate-700\"\n                >\n                  \\{showPassword \\? <EyeOff className=\"w-5 h-5\" /> : <Eye className=\"w-5 h-5\" />\\}\n                </button>\n              </div>\n            </div>\n\n            <div>\n              <label className=\"block text-sm font-medium text-slate-700 mb-2\">Confirm password</label>\n              <div className=\"relative\">\n                <div className=\"pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3 text-slate-400\">\n                  <Lock className=\"w-5 h-5\" />\n                </div>\n                <input\n                  type=\\{showConfirmPassword \\? \"text\" : \"password\"\\}\n                  value=\\{confirmPassword\\}\n                  onChange=\\{\\(event\\) => setConfirmPassword\\(event\\.target\\.value\\)\\}\n                  placeholder=\"Repeat your password\"\n                  required\n                  className=\"w-full rounded-2xl border border-slate-200 bg-slate-50 py-3 pl-12 pr-12 text-sm text-slate-900 outline-none transition focus:border-blue-500 focus:ring-2 focus:ring-blue-500/10\"\n                />\n                <button\n                  type=\"button\"\n                  onClick=\\{\\(\\) => setShowConfirmPassword\\(\\(current\\) => !current\\)\\}\n                  className=\"absolute inset-y-0 right-0 flex items-center pr-3 text-slate-500 hover:text-slate-700\"\n                >\n                  \\{showConfirmPassword \\? <EyeOff className=\"w-5 h-5\" /> : <Eye className=\"w-5 h-5\" />\\}\n                </button>\n              </div>\n            </div>\n\n            <button\n              type=\"submit\"\n              disabled=\\{loading\\}\n              className=\"w-full rounded-2xl bg-blue-600 py-3 text-sm font-semibold text-white transition hover:bg-blue-700 disabled:cursor-not-allowed disabled:opacity-60\"\n            >\n              \\{loading \\? \"Creating account\\.\\.\\.\" : \"Create Account\"\\}\n            </button>\n          </form>\n\n          <div className=\"mt-6 flex items-center justify-center gap-2 text-sm text-slate-500\">\n            <span>Already have an account\\?</span>\n            <Link to=\"/login\" className=\"font-semibold text-blue-600 hover:text-blue-700\">\n              Sign in\n            </Link>\n          </div>\n        </motion\\.div>\n      </div>\n    </div>\n  \\);\n\\};\n\nexport default Register;\n'''\npath\\.write_text\\(content, encoding='utf-8'\\)\nPY$/": {
